.pd2b.bg-img-setting
  display inline-block
  padding 0
  margin 5px 5px 0 0
.font-sel
  min-width 200px
.setting-wrap .app-drag
  position fixed
  top 0
  left 43px
  height 60px
  right 0
  z-index 888
.deep-link-btns
  display flex
  flex-wrap wrap
  gap 8px

// passwords list — replaces the old table so content wraps
// instead of forcing horizontal scroll on narrow/mobile screens
.setting-passwords-list
  border 1px solid var(--main-light)
  border-radius 6px
  overflow hidden
  margin 8px 0
  .setting-passwords-item
    padding 8px 12px
    &:not(:last-child)
      border-bottom 1px solid var(--main-light)
.setting-passwords-item
  .setting-passwords-item-inner
    display flex
    flex-wrap wrap
    align-items center
    gap 8px
    width 100%
  .setting-passwords-pwd-cell
    flex-shrink 0
  .setting-passwords-count-cell
    flex-shrink 0
    margin 0
  .setting-passwords-host-cell
    flex 1 1 120px
    min-width 120px
    word-break break-all
    line-height 1.5
  .setting-passwords-actions-cell
    flex-shrink 0
    margin-left auto