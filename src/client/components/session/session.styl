@require '../../css/includes/theme-default'
@keyframes rotate
  from
    background-position -3000px
  to
    background-position 0px
.type-tab-line
  position absolute
  bottom 0
  left 0
  width 100%
  height 1px
  background text-dark
  display none
.type-tab-txt
  position relative
  display inline-block

.sftp-follow-ssh-icon
.type-tab
  display inline-block
  vertical-align middle
  line-height 30px
  color text-dark
  padding 0 20px 0 0
  margin-right 0px
  font-size 14px
  cursor pointer
  &:hover
  &.active
    color text
  &.active
    .type-tab-line
      display inline-block

.is-transporting
  .type-tab.sftp
    .type-tab-line
      display inline-block
      background linear-gradient(to right, success 0%, main 25%, error 50%, primary 75%, success 100%)
      animation: rotate 60s infinite linear
.disable-ssh
  .type-tab.ssh
    display none
.spliter
  color text
  font-size 16px
  &:hover
    color text-light

.session-wrap
  display none
.session-current
  display block
.no-sessions
  background main-dark
  text-align center
  padding 50px 0
.web-session-wrap
  height 100vh
  background main
.session-v-wrap
  background main
  overflow scroll
  z-index 99
.vnc-session-wrap > div
  display block !important
  width auto !important
  height auto !important

// bookmarks
bookmark-width = 25rem
bookmark-height = 10rem
border-color=rgb(84, 84, 84)

.panel
  margin: 10px

  input[type="search"]
    margin-bottom: 5px
  .bookmarks
    display: grid
    justify-content: start
    grid-template-columns: repeat(auto-fill, minmax(bookmark-width, 1fr)) // Используем minmax для адаптивности
    grid-template-rows: repeat(auto-fill, 1fr)
    border: 2px solid border-color
    min-height: 100px
    gap: 5px
    padding: 5px
    overflow: auto
    max-height: calc(100vh - 125px)

    .runScripts-limit
      max-height: 5rem
      max-width: 15rem
      overflow: hidden
    .clipboard
      cursor: pointer
      &:hover
        opacity: 0.8
      

    .bookmark
      border: 2px solid border-color
      padding: 1rem
      width: 100%
      height: auto
      background-color: rgba(50, 50, 50, 0.8)
      border-radius: 5px
      transition: transform 0.2s
      min-height: bookmark-height
      min-width bookmark-width
      display: flex
      flex-direction: column
      justify-content: space-between

      &:hover
        transform: scale(1.02)

      .bookmark-header
        display: flex
        justify-content: space-between
        align-items: center
        margin-bottom: 0.5rem

        .color-indicator
          border: 1px solid border-color
          width: 15px 
          height: 15px 
          border-radius: 3px 
          margin-right: 0.5rem

        .badge
          text-transform: uppercase
          background-color: rgba(255, 255, 255, 0.2)
          padding: 0.2rem 0.5rem
          border-radius: 3px
          margin-right: 0.5rem // Отступ слева от значка  

        h3
          word-break: break-all;
          margin: 0
          font-size: 1.2rem
          flex-grow: 1

        .protocol
          background-color: rgba(255, 255, 255, 0.2)
          padding: 0.2rem 0.5rem
          font-size: 0.7rem
          border-radius: 3px

      .bookmark-body
        margin-bottom: 0.5rem
        color: #ddd
        flex-grow: 1

        p
          margin: 0.2rem 0

      .bookmark-footer
        text-align: right
        margin-top: auto

        .connect-button
          background-color: rgb(3, 119, 176)
          border: none
          padding: 0.5rem 1rem
          border-radius: 3px
          cursor: pointer
          transition: background-color 0.2s

          &:hover
            background-color: rgb(34, 148, 197)

        .edit-button
          margin-right: 0.5rem 
          background-color: rgb(38, 38, 38)
          color: #fff
          border: 1px dashed rgb(84, 84, 84)
          padding: 0.5rem 1rem
          border-radius: 3px
          cursor: pointer
          transition: background-color 0.2s

          &:hover
            color: rgb(34, 148, 197)
            border-color: rgb(34, 148, 197)