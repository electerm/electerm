.main-footer
  background var(--main)
  height 36px
  position absolute
  left 44px
  right 0
  bottom 0
  z-index 200
.pinned
  .main-footer
  .qm-wrap-tooltip
    left 343px

.terminal-footer-flex
  display flex
  .terminal-footer-unit .ant-select-selector .ant-select-selection-placeholder
    line-height 24px
.terminal-footer-unit
  margin-left 10px
  line-height 39px
  textarea.ant-input
    min-height 26px
    height 26px
    margin-bottom -2px
    resize none
    &::-webkit-scrollbar
      width 0

.terminal-footer-center
  flex-grow 1
.terminal-footer-info
  margin-right 10px
  line-height 39px
.terminal-footer-history
  display flex
  align-items center
.terminal-footer-qm
  // Q is now an icon-only button (5px internal padding); reduce left
  // margin so the history icon stays roughly equidistant from AI and Q
  margin-left 3px
.batch-input-outer
  position relative
  .bi-full
    display none
  &.bi-show
    // hide the trigger while the popup is open so we don't show two
    // "batch input" fields at once (desktop trigger is an input-shaped affordance)
    .bi-compact
      display none
    .bi-full
      display flex
      flex-direction column
      gap 6px
      position absolute
      bottom 100%
      left 0
      z-index 1000
      background var(--main)
      padding 8px 10px
      box-shadow 0 -2px 8px rgba(0, 0, 0, 0.2)
      border-radius 4px 4px 0 0
      min-width 360px
.batch-input-holder
  width 100px