.qm-list-wrap
  max-height calc(100vh - 100px)
  overflow-y scroll
  padding 20px 0 10px 0
.qm-wrap-tooltip
  background var(--main)
  position absolute
  left 43px
  right 0
  z-index 89
  height auto
  bottom 36px

.qm-pinned
  .qm-wrap-tooltip
    height 180px
  .qm-list-wrap
    max-height 100px

.qm-search-input
  max-width 200px
@media (max-width: 500px)
  .qm-search-input
    width 100px

.item-list-unit.dragover
  border: 1px dashed var(--primary)
.qm-item-dragover
  border-left 2px solid var(--primary)
.qm-field-dragging
  opacity 0.4
.qm-field-dragover
  border-top 2px solid var(--primary)
.qm-label-select
  min-width 120px
.qm-name-input
  max-width 160px
  min-width 80px

.qm-flex
  gap 8px

.qm-tooltip-content
  max-width 360px
  .qm-tooltip-title
    font-weight 600
    margin-bottom 4px
    word-break break-word
  .qm-tooltip-cmd-list
    margin 0
    padding 0
    list-style none
    .qm-tooltip-cmd-item
      padding 4px 0
      border-top 1px solid rgba(255,255,255,0.15)
      &:first-child
        border-top none
      .qm-tooltip-label
        opacity 0.65
        margin-right 4px
      .qm-tooltip-value
        word-break break-word
      code
        font-family monospace
  .qm-tooltip-meta
    margin-top 4px
    padding-top 4px
    border-top 1px solid rgba(255,255,255,0.15)
    .qm-tooltip-label
      opacity 0.65
      margin-right 4px

@media (max-width: 768px)
  .qm-flex
    flex-direction column
    align-items flex-start
  .qm-search-input
    max-width none
    width 100%
  .qm-label-select
    width 100%

// On mobile, stack the quick-command row (name / delay / command / remove)
// vertically instead of side by side — the horizontal Space.Compact layout
// is too cramped on narrow screens.
.is-mobile
  .qm-cmd-row.ant-space-compact
    display flex
    flex-direction column
    align-items stretch
    gap 8px
    .ant-space-compact-item
      width 100%
    // reset the constrained widths so inputs fill the row when stacked
    .qm-name-input
      max-width none
      width 100%
    .ant-input-number
      width 100% !important
    // keep the drag handle + remove button on a tidy line of their own
    > .drag
      align-self flex-start
    > button:last-child
      align-self flex-end