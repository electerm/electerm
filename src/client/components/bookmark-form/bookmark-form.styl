.mg24b
  margin-bottom 24px
.mg60b
  margin-bottom 60px
.compact-input input
  width 80px !important
.ssh-tunnels-host
  margin-bottom 0
.ip-item
   line-height 34px
  .item-item-use
    display none
.ip-item:hover
    .item-item-use
      display inline-block
.number-input
  min-width 210px

// On mobile, stack loginScriptDelay and loginScript vertically instead of
// horizontally (the antd Space renders them side by side by default).
.is-mobile
  .run-scripts-space.ant-space
    flex-direction column
    align-items stretch
    .ant-space-item
      width 100%

.tree-select-wrapper
  display flex
  flex-direction column
  height 100%
  overflow hidden

.tree-select-header
  flex-shrink 0

.tree-select-content
  flex 1
  overflow auto
  margin-top 8px

.bookmark-json-preview
  padding 12px
  max-height 300px
  overflow auto
  font-size 12px
  font-family monospace

// Flash the add/save button when the form has unsaved edits,
// so users remember to click it instead of losing their input.
.btn-flash
  animation add-btn-flash 1.1s ease-in-out infinite

@keyframes add-btn-flash
  0%, 100%
    box-shadow 0 0 0 0 var(--primary)
    transform scale(1)
  50%
    box-shadow 0 0 8px 2px var(--primary)
    transform scale(1.04)

@media (prefers-reduced-motion: reduce)
  .btn-flash
    animation none
