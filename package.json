{
  "name": "electerm",
  "version": "3.15.110",
  "description": "Terminal/ssh/telnet/serialport/sftp client(linux, mac, win)",
  "main": "app.js",
  "bin": "npm/electerm",
  "scripts": {
    "app": "node build/bin/app",
    "build": "npm run vite-build",
    "start": "node build/bin/start.js",
    "icon": "node build/bin/icon",
    "clean": "node build/bin/clean",
    "compile": "node build/bin/build",
    "vite-build": "node build/bin/vite-build.js",
    "postpublish": "node build/bin/postpublish",
    "prepare-file": "node build/bin/prepare",
    "pb": "node build/bin/prepare-electron-build.js",
    "prepare-test": "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 npm i -E playwright@1.28.1 --no-save && npm i -E @playwright/test@1.28.1 --no-save",
    "postinstall": "node build/bin/post-install",
    "lint": "./node_modules/.bin/standard --verbose",
    "fix": "./node_modules/.bin/standard --fix",
    "test": "npm run test1 && npm run test2",
    "test-unit-ci": "node --test test/unit-ci/*.spec.js",
    "test1": "./node_modules/.bin/playwright test test/e2e/00*.js --workers=1",
    "test2": "./node_modules/.bin/playwright test test/e2e/01*.js --workers=1",
    "test3": "./node_modules/.bin/playwright test test/e2e/02*.js --workers=1 && npm run test-unit-ci",
    "b": "npm run clean && npm run compile && npm run prepare-file",
    "r": "./build/bin/release",
    "w": "./build/bin/web-release",
    "t": "./node_modules/.bin/electron work/app/app.js",
    "lock": "npm i --package-lock-only"
  },
  "license": "MIT",
  "langugeRepo": "https://github.com/electerm/electerm-locales",
  "privacyNoticeLink": "https://github.com/electerm/electerm/wiki/privacy-notice",
  "knownIssuesLink": "https://github.com/electerm/electerm/wiki/Know-issues",
  "sponsorLink": "https://electerm.org/sponsor-electerm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/electerm/electerm.git"
  },
  "author": {
    "name": "ZHAO Xudong",
    "email": "zxdong@gmail.com",
    "url": "https://github.com/zxdong262"
  },
  "bugs": {
    "url": "https://github.com/electerm/electerm/issues"
  },
  "homepage": "https://electerm.org",
  "releases": "https://github.com/electerm/electerm/releases",
  "engines": {
    "node": ">=16.0.0"
  },
  "preferGlobal": true,
  "devDependencies": {
    "@ant-design/icons": "6.2.5",
    "@electerm/electerm-resource": "2.1.7",
    "@fontsource/maple-mono": "^5.2.5",
    "@novnc/novnc": "1.7.0",
    "@types/node": "22.9.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@xterm/addon-attach": "0.13.0-beta.288",
    "@xterm/addon-fit": "0.12.0-beta.288",
    "@xterm/addon-image": "0.10.0-beta.288",
    "@xterm/addon-ligatures": "0.11.0-beta.288",
    "@xterm/addon-search": "0.17.0-beta.288",
    "@xterm/addon-unicode11": "0.10.0-beta.288",
    "@xterm/addon-web-links": "0.13.0-beta.288",
    "@xterm/addon-webgl": "0.20.0-beta.287",
    "@xterm/xterm": "6.1.0-beta.288",
    "antd": "6.4.5",
    "classnames": "2.5.1",
    "cross-env": "7.0.3",
    "dotenv": "16.4.5",
    "electerm-icons": "1.0.1",
    "electron": "41.2.0",
    "electron-builder": "26.9.0",
    "filesize": "10.1.6",
    "filesize-parser": "1.5.1",
    "glob": "^13.0.6",
    "ironrdp-wasm": "1.1.0",
    "lodash-es": "^4.17.21",
    "manate": "2.0.3",
    "morgan": "1.11.0",
    "multer": "^2.2.0",
    "pug": "3.0.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "9.0.1",
    "replace-in-file": "6.3.5",
    "shelljs": "0.8.5",
    "spice-client": "1.2.0",
    "standard": "^17.1.2",
    "stylus": "^0.64.0",
    "vite": "8.1.0"
  },
  "dependencies": {
    "@electerm/electerm-locales": "2.2.16",
    "@electerm/electerm-themes": "^1.0.1",
    "@electerm/ftp-srv": "1.0.5",
    "@electerm/nedb": "2.0.0",
    "@electerm/ssh2": "1.19.0",
    "@xterm/headless": "6.1.0-beta.288",
    "axios": "1.18.1",
    "basic-ftp": "6.0.1",
    "commander": "12.1.0",
    "diffie-hellman": "^5.0.3",
    "electerm-sync": "2.0.0",
    "electron-log": "4.3.5",
    "express": "5.2.1",
    "express-ws": "5.0.2",
    "fast-deep-equal": "3.1.3",
    "find-free-port": "2.0.0",
    "font-list": "1.5.1",
    "https-proxy-agent": "7.0.1",
    "iconv-lite": "^0.7.2",
    "json-deep-copy": "1.3.1",
    "jsonwebtoken": "^9.0.1",
    "nanoid": "3.3.8",
    "node-bash": "5.0.1",
    "node-forge": "1.4.0",
    "node-pty": "1.1.0-beta34",
    "os-locale-s": "1.1.3",
    "serialport": "13.0.0",
    "socks": "2.8.9",
    "socks-proxy-agent": "8.0.1",
    "socksv5-server": "^1.0.2",
    "ssh-config-loader": "1.1.2",
    "ssh2-scp": "3.2.0",
    "tar": "7.5.17",
    "trzsz2": "1.2.0",
    "zmodem2": "1.4.0"
  },
  "files": [
    "npm",
    "README.md",
    "LICENSE"
  ],
  "standard": {
    "sourceType": "module",
    "ignore": [
      "work",
      "temp",
      "dist"
    ],
    "globals": [
      "log",
      "MouseEvent",
      "WebSocket",
      "FileReader",
      "CustomEvent",
      "onmessage",
      "requestAnimationFrame",
      "self"
    ]
  }
}
